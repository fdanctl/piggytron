package partials

import "github.com/fdanctl/piggytron/web/templates/components"

templ Test() {
	<style>
		#my-btn {
			anchor-name: --Profile-button;
			width: fit-content;
		}
		#mypop {
			display: none;
			/* anchoring to the button */
			position: absolute;
			position-anchor: --Profile-button;
			margin: 0;
			inset: auto;
			bottom: anchor(bottom);
			left: anchor(right);
			opacity: 0;
			transition:
				opacity 1s,
				display 1s,
				overlay 1s;
			transition-behavior: allow-discrete;

			position-try-fallbacks: --left;

			margin-left: 0.25rem;
		}
		#mypop:popover-open {
			display: grid;
			opacity: 1;
		}
	</style>
	<div>
		<div
			id="my-btn"
			onmouseenter="document.getElementById('mypop').showPopover();"
			onmouseleave="document.getElementById('mypop').hidePopover();"
		>
			open
		</div>
	</div>
	<div>
		<div id="mypop" popover>
			<p>this is a text</p>
		</div>
	</div>
	@components.Dropdown("", "one", false) {
		<h1>hello one</h1>
	}
	@components.Dropdown("", "t", false) {
		<h1>hello two</h1>
	}
	@components.InputGroup("", "label", "hello error", false, true, nil)
	@components.InputGroup("", "label", "hello error", true, true, nil)
	@components.Input("", false, nil)
	@components.Input("", true, nil)
	@components.SearchBar("", nil)
	@components.DateInput("", false, templ.Attributes{"placeholder": "dd/mm/yyyy"})
	@components.Input("", false, templ.Attributes{"type": "time"})
	@components.TimeInput("", false, nil)
}
