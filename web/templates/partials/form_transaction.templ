				components.BtnPrimary,
				components.BtnMedium,
				templ.Attributes{
					"type": "submit",
				},
			)
		</div>
	</form>
}

templ GoalContributionForm(v views.TransferForm, categories, accounts []components.SelectOption) {
	<form
		class="space-y-sm"
		hx-on:submit="event.preventDefault()"
		hx-post={ fmt.Sprintf("/partials/goal-contribute/%s", v.DestinationAcc) }
		hx-swap="outerHTML"
		novalidate
	>
		<input type="hidden" name="type" value="transfer"/>
		<div class="grid gap-xs" style="grid-template-columns: 1.5fr 1fr;">
			@components.InputGroup(
				"",
				"Amount",
				views.StringArrToStr(v.ValidateAmount()),
				v.AmountHasError(),
				true,
				templ.Attributes{
					"id":            "transfer-amount",
					"type":          "text",
					"name":          "amount",
					"placeholder":   "420.69",
					"value":         v.Amount,
					"data-focus":    "ui.cash-input.focus",
					"data-focusout": "ui.cash-input.blur",
					"data-input":    "ui.cash-input.input",
				},
			)
			@components.SelectGroup(
				"",
				"Currency",
				v.Currency,
				"-- Select currency --",
				[]components.SelectOption{
					{
						Label: "EUR",
						Value: "EUR",
					},
				},
				views.StringArrToStr(v.ValidateCurrency()),
				v.CurrencyHasError(),
				true,
				templ.Attributes{
					"id":   "currency",
					"name": "currency",
				},
			)
		</div>
		@components.InputGroup(
			"",
			"Description",
			views.StringArrToStr(v.ValidateDescription()),
			v.DescriptionHasError(),
			true,
			templ.Attributes{
				"id":          "transfer-description",
				"type":        "text",
				"name":        "description",
				"placeholder": "Salary",
				"value":       v.Description,
			},
		)
		@components.DateInputGroup(
			"w-full",
			"Date",
			views.StringArrToStr(v.ValidateDate()),
			v.DateHasError(),
			true,
			templ.Attributes{
				"id":    "transfer-date",
				"type":  "text",
				"name":  "date",
				"value": v.Date,
			},
		)
		{{
			index := slices.IndexFunc(categories, func(e components.SelectOption) bool {
				return e.Value == v.Category
			})
			var label string
			if index > 0 {
				label = categories[index].Label
			}
		}}
		@components.InputGroup(
			"",
			"Category",
			views.StringArrToStr(v.ValidateCategory()),
			v.CategoryHasError(),
			true,
			templ.Attributes{
				"id":       "category",
				"disabled": "true",
				"value":    label,
			},
		)
		<input type="hidden" name="category" value={ v.Category }/>
		{{
			i := slices.IndexFunc(accounts, func(e components.SelectOption) bool {
				return e.Value == v.DestinationAcc
			})
			accounts = append(accounts[:i], accounts[i+1:]...)
		}}
		@components.SelectGroup(
			"",
			"From",
			v.SourceAcc,
			"-- Select account --",
			accounts,
			views.StringArrToStr(v.ValidateSourceAcc()),
			v.SourceAccHasError(),
			true,
			templ.Attributes{
				"id":   "transfer-source",
				"name": "source",
			},
		)
		<input type="hidden" name="destination" value={ v.DestinationAcc }/>
		<div class="w-full flex justify-end mt-md">
			@components.Button(
				"Contribute",
				"mt-md",
				components.BtnPrimary,
				components.BtnMedium,
				templ.Attributes{
					"type": "submit",
				},
			)
		</div>
	</form>
}
