			templ.Attributes{
				"id":    "transfer-date",
				"type":  "text",
				"name":  "date",
				"value": v.Date,
			},
		)
		@components.SelectGroup(
			"",
			"Category",
			v.Category,
			"-- Select category --",
			categories,
			views.StringArrToStr(v.ValidateCategory()),
			v.CategoryHasError(),
			false,
			templ.Attributes{
				"id":   "transfer-category",
				"name": "category",
			},
		)
		@components.SelectGroup(
			"",
			"From",
